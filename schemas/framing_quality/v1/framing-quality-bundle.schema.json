{
  "$defs": {
    "ActiveMarginWitness": {
      "additionalProperties": false,
      "description": "A diagnostic payoff comparison for one choice-dependent mechanism link.",
      "properties": {
        "activity_status": {
          "enum": [
            "active",
            "inactive",
            "unresolved"
          ],
          "title": "Activity Status",
          "type": "string"
        },
        "alternative_action": {
          "minLength": 1,
          "title": "Alternative Action",
          "type": "string"
        },
        "alternative_payoff": {
          "minLength": 1,
          "title": "Alternative Payoff",
          "type": "string"
        },
        "best_response_inequality": {
          "minLength": 1,
          "title": "Best Response Inequality",
          "type": "string"
        },
        "concrete_state": {
          "minLength": 1,
          "title": "Concrete State",
          "type": "string"
        },
        "consequence_binding": {
          "anyOf": [
            {
              "$ref": "#/$defs/ChoiceConsequenceBinding"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "decision_maker": {
          "minLength": 1,
          "title": "Decision Maker",
          "type": "string"
        },
        "decision_node_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Decision Node Id",
          "type": "string"
        },
        "feasibility_basis": {
          "minLength": 1,
          "title": "Feasibility Basis",
          "type": "string"
        },
        "focal_action": {
          "minLength": 1,
          "title": "Focal Action",
          "type": "string"
        },
        "focal_payoff": {
          "minLength": 1,
          "title": "Focal Payoff",
          "type": "string"
        },
        "kill_condition": {
          "minLength": 1,
          "title": "Kill Condition",
          "type": "string"
        },
        "payoff_node_ids": {
          "items": {
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
            "type": "string"
          },
          "minItems": 1,
          "title": "Payoff Node Ids",
          "type": "array"
        },
        "status_basis": {
          "minLength": 1,
          "title": "Status Basis",
          "type": "string"
        }
      },
      "required": [
        "decision_node_id",
        "payoff_node_ids",
        "concrete_state",
        "decision_maker",
        "focal_action",
        "alternative_action",
        "focal_payoff",
        "alternative_payoff",
        "feasibility_basis",
        "best_response_inequality",
        "activity_status",
        "status_basis",
        "kill_condition"
      ],
      "title": "ActiveMarginWitness",
      "type": "object"
    },
    "AggregateInvarianceAssessment": {
      "additionalProperties": false,
      "properties": {
        "aggregate_object": {
          "minLength": 1,
          "title": "Aggregate Object",
          "type": "string"
        },
        "basis": {
          "minLength": 1,
          "title": "Basis",
          "type": "string"
        },
        "claims_aggregate_fixed": {
          "title": "Claims Aggregate Fixed",
          "type": "boolean"
        },
        "implication_for_attribution": {
          "minLength": 1,
          "title": "Implication For Attribution",
          "type": "string"
        },
        "pointwise_policy_fixed": {
          "title": "Pointwise Policy Fixed",
          "type": "boolean"
        },
        "weighting_distribution_status": {
          "enum": [
            "fixed",
            "endogenous",
            "changed",
            "not_applicable",
            "unresolved"
          ],
          "title": "Weighting Distribution Status",
          "type": "string"
        }
      },
      "required": [
        "aggregate_object",
        "pointwise_policy_fixed",
        "weighting_distribution_status",
        "claims_aggregate_fixed",
        "basis",
        "implication_for_attribution"
      ],
      "title": "AggregateInvarianceAssessment",
      "type": "object"
    },
    "ArchetypeTension": {
      "additionalProperties": false,
      "description": "The reader's prior and the archetype-specific source of tension.",
      "properties": {
        "conventional_prediction": {
          "minLength": 1,
          "title": "Conventional Prediction",
          "type": "string"
        },
        "countervailing_logic": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Countervailing Logic"
        },
        "economic_puzzle": {
          "minLength": 1,
          "title": "Economic Puzzle",
          "type": "string"
        },
        "resolution_target": {
          "minLength": 1,
          "title": "Resolution Target",
          "type": "string"
        },
        "result_archetype": {
          "enum": [
            "mechanism_explanation",
            "comparative_statics_threshold",
            "characterization_bounds",
            "robustness_invariance_equivalence",
            "design_implementation_impossibility",
            "concept_representation_foundation"
          ],
          "title": "Result Archetype",
          "type": "string"
        },
        "tension_kind": {
          "enum": [
            "causal_channel",
            "force_conflict",
            "sign_or_threshold_reversal",
            "boundary_or_tightness",
            "invariance_or_equivalence",
            "design_tradeoff_or_impossibility",
            "conceptual_distinction_or_representation"
          ],
          "title": "Tension Kind",
          "type": "string"
        }
      },
      "required": [
        "result_archetype",
        "tension_kind",
        "conventional_prediction",
        "economic_puzzle",
        "resolution_target"
      ],
      "title": "ArchetypeTension",
      "type": "object"
    },
    "BenchmarkFramingAssessment": {
      "additionalProperties": false,
      "description": "One semantic ledger row bound to a nested benchmark ID.",
      "properties": {
        "aggregate_invariance": {
          "$ref": "#/$defs/AggregateInvarianceAssessment"
        },
        "attribution_basis": {
          "minLength": 1,
          "title": "Attribution Basis",
          "type": "string"
        },
        "attribution_strength": {
          "enum": [
            "clean",
            "qualified",
            "weak",
            "unresolved"
          ],
          "title": "Attribution Strength",
          "type": "string"
        },
        "benchmark_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Benchmark Id",
          "type": "string"
        },
        "changed": {
          "items": {
            "$ref": "#/$defs/FramingObjectRef"
          },
          "minItems": 1,
          "title": "Changed",
          "type": "array"
        },
        "channel_kind": {
          "enum": [
            "active_response",
            "boundary_or_mapping",
            "diagnostic_only"
          ],
          "title": "Channel Kind",
          "type": "string"
        },
        "channel_path": {
          "items": {
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
            "type": "string"
          },
          "minItems": 2,
          "title": "Channel Path",
          "type": "array"
        },
        "channel_summary": {
          "minLength": 1,
          "title": "Channel Summary",
          "type": "string"
        },
        "distinctive_mechanism": {
          "anyOf": [
            {
              "$ref": "#/$defs/DistinctiveMechanismAssessment"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "held_fixed": {
          "items": {
            "$ref": "#/$defs/HeldFixedObjectRef"
          },
          "minItems": 1,
          "title": "Held Fixed",
          "type": "array"
        },
        "reoptimizing": {
          "items": {
            "$ref": "#/$defs/FramingObjectRef"
          },
          "title": "Reoptimizing",
          "type": "array"
        },
        "selection_assurance": {
          "$ref": "#/$defs/SelectionAssurance"
        },
        "still_endogenous": {
          "items": {
            "$ref": "#/$defs/FramingObjectRef"
          },
          "minItems": 1,
          "title": "Still Endogenous",
          "type": "array"
        },
        "targets": {
          "items": {
            "$ref": "#/$defs/FramingObjectRef"
          },
          "minItems": 1,
          "title": "Targets",
          "type": "array"
        }
      },
      "required": [
        "benchmark_id",
        "changed",
        "held_fixed",
        "reoptimizing",
        "still_endogenous",
        "targets",
        "channel_kind",
        "channel_path",
        "channel_summary",
        "aggregate_invariance",
        "selection_assurance",
        "attribution_strength",
        "attribution_basis"
      ],
      "title": "BenchmarkFramingAssessment",
      "type": "object"
    },
    "CausalChainStep": {
      "additionalProperties": false,
      "properties": {
        "active_margin_witness": {
          "anyOf": [
            {
              "$ref": "#/$defs/ActiveMarginWitness"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "cause": {
          "minLength": 1,
          "title": "Cause",
          "type": "string"
        },
        "consequence": {
          "minLength": 1,
          "title": "Consequence",
          "type": "string"
        },
        "endogenous_response": {
          "minLength": 1,
          "title": "Endogenous Response",
          "type": "string"
        },
        "force_ids": {
          "items": {
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
            "type": "string"
          },
          "minItems": 1,
          "title": "Force Ids",
          "type": "array"
        },
        "source_node_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Source Node Id",
          "type": "string"
        },
        "step_number": {
          "enum": [
            1,
            2,
            3
          ],
          "title": "Step Number",
          "type": "integer"
        },
        "target_node_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Target Node Id",
          "type": "string"
        }
      },
      "required": [
        "step_number",
        "force_ids",
        "cause",
        "endogenous_response",
        "consequence",
        "source_node_id",
        "target_node_id"
      ],
      "title": "CausalChainStep",
      "type": "object"
    },
    "ChoiceConsequenceBinding": {
      "additionalProperties": false,
      "description": "Bind one payoff comparison to the consequence its action can change.",
      "properties": {
        "alternative_consequence": {
          "minLength": 1,
          "title": "Alternative Consequence",
          "type": "string"
        },
        "causal_edge_ids": {
          "items": {
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
            "type": "string"
          },
          "minItems": 1,
          "title": "Causal Edge Ids",
          "type": "array"
        },
        "consequence_node_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Consequence Node Id",
          "type": "string"
        },
        "feasibility_basis": {
          "minLength": 1,
          "title": "Feasibility Basis",
          "type": "string"
        },
        "focal_consequence": {
          "minLength": 1,
          "title": "Focal Consequence",
          "type": "string"
        },
        "public_state_conditions": {
          "items": {
            "$ref": "#/$defs/PublicStateCondition"
          },
          "minItems": 1,
          "title": "Public State Conditions",
          "type": "array"
        },
        "transition_kind": {
          "enum": [
            "increase",
            "decrease",
            "switch",
            "reweight"
          ],
          "title": "Transition Kind",
          "type": "string"
        }
      },
      "required": [
        "consequence_node_id",
        "transition_kind",
        "causal_edge_ids",
        "public_state_conditions",
        "focal_consequence",
        "alternative_consequence",
        "feasibility_basis"
      ],
      "title": "ChoiceConsequenceBinding",
      "type": "object"
    },
    "DisclosedFramingGap": {
      "additionalProperties": false,
      "properties": {
        "affected_benchmark_ids": {
          "default": [],
          "items": {
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
            "type": "string"
          },
          "title": "Affected Benchmark Ids",
          "type": "array"
        },
        "category": {
          "enum": [
            "benchmark_semantics",
            "aggregate_endogeneity",
            "equilibrium_selection",
            "reoptimization",
            "causal_attribution",
            "scope",
            "minimal_example",
            "other"
          ],
          "title": "Category",
          "type": "string"
        },
        "consequence": {
          "minLength": 1,
          "title": "Consequence",
          "type": "string"
        },
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "gap_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Gap Id",
          "type": "string"
        },
        "repair_target_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/FramingRepairTargetRef"
          },
          "title": "Repair Target Refs",
          "type": "array"
        },
        "resolution_needed": {
          "minLength": 1,
          "title": "Resolution Needed",
          "type": "string"
        }
      },
      "required": [
        "gap_id",
        "category",
        "description",
        "consequence",
        "resolution_needed"
      ],
      "title": "DisclosedFramingGap",
      "type": "object"
    },
    "DistinctiveMechanismAssessment": {
      "additionalProperties": false,
      "description": "Declare whether one benchmark carries a mechanism absent from a contrast.",
      "properties": {
        "basis": {
          "minLength": 1,
          "title": "Basis",
          "type": "string"
        },
        "claim_kind": {
          "enum": [
            "not_claimed",
            "choice_mediated",
            "mechanical_transition",
            "unresolved"
          ],
          "title": "Claim Kind",
          "type": "string"
        },
        "consequence_node_id": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Consequence Node Id"
        },
        "contrast_benchmark_id": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Contrast Benchmark Id"
        },
        "distinctive_edge_ids": {
          "default": [],
          "items": {
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
            "type": "string"
          },
          "title": "Distinctive Edge Ids",
          "type": "array"
        },
        "distinctive_node_ids": {
          "default": [],
          "items": {
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
            "type": "string"
          },
          "title": "Distinctive Node Ids",
          "type": "array"
        },
        "mechanism_label": {
          "minLength": 1,
          "title": "Mechanism Label",
          "type": "string"
        },
        "required_public_state_conditions": {
          "default": [],
          "items": {
            "$ref": "#/$defs/PublicStateCondition"
          },
          "title": "Required Public State Conditions",
          "type": "array"
        },
        "transition_kind": {
          "anyOf": [
            {
              "enum": [
                "increase",
                "decrease",
                "switch",
                "reweight"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Transition Kind"
        }
      },
      "required": [
        "claim_kind",
        "mechanism_label",
        "basis"
      ],
      "title": "DistinctiveMechanismAssessment",
      "type": "object"
    },
    "EconomicForce": {
      "additionalProperties": false,
      "properties": {
        "active_when": {
          "minLength": 1,
          "title": "Active When",
          "type": "string"
        },
        "direction": {
          "enum": [
            "raises_target",
            "lowers_target",
            "changes_composition",
            "changes_constraint",
            "ambiguous"
          ],
          "title": "Direction",
          "type": "string"
        },
        "economic_logic": {
          "minLength": 1,
          "title": "Economic Logic",
          "type": "string"
        },
        "force_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Force Id",
          "type": "string"
        },
        "label": {
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "margin_node_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Margin Node Id",
          "type": "string"
        },
        "operative_margin": {
          "minLength": 1,
          "title": "Operative Margin",
          "type": "string"
        },
        "role": {
          "enum": [
            "baseline_force",
            "countervailing_force",
            "equilibrium_feedback",
            "boundary_force"
          ],
          "title": "Role",
          "type": "string"
        },
        "source_node_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Source Node Id",
          "type": "string"
        },
        "target_node_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Target Node Id",
          "type": "string"
        }
      },
      "required": [
        "force_id",
        "label",
        "role",
        "operative_margin",
        "direction",
        "economic_logic",
        "active_when",
        "source_node_id",
        "margin_node_id",
        "target_node_id"
      ],
      "title": "EconomicForce",
      "type": "object"
    },
    "EconomistMemo": {
      "additionalProperties": false,
      "description": "Fields needed for a compact economist-facing framing memo.",
      "properties": {
        "benchmark_message": {
          "minLength": 1,
          "title": "Benchmark Message",
          "type": "string"
        },
        "contribution_message": {
          "minLength": 1,
          "title": "Contribution Message",
          "type": "string"
        },
        "headline": {
          "minLength": 1,
          "title": "Headline",
          "type": "string"
        },
        "mechanism_message": {
          "minLength": 1,
          "title": "Mechanism Message",
          "type": "string"
        },
        "opening_question": {
          "minLength": 1,
          "title": "Opening Question",
          "type": "string"
        },
        "reader_takeaway": {
          "minLength": 1,
          "title": "Reader Takeaway",
          "type": "string"
        },
        "result_preview": {
          "minLength": 1,
          "title": "Result Preview",
          "type": "string"
        },
        "scope_condition": {
          "minLength": 1,
          "title": "Scope Condition",
          "type": "string"
        },
        "tension_message": {
          "minLength": 1,
          "title": "Tension Message",
          "type": "string"
        }
      },
      "required": [
        "headline",
        "opening_question",
        "benchmark_message",
        "tension_message",
        "mechanism_message",
        "result_preview",
        "contribution_message",
        "scope_condition",
        "reader_takeaway"
      ],
      "title": "EconomistMemo",
      "type": "object"
    },
    "EntityVersionRef": {
      "additionalProperties": false,
      "properties": {
        "entity_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Entity Id",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "entity_id",
        "version"
      ],
      "title": "EntityVersionRef",
      "type": "object"
    },
    "FramingObjectRef": {
      "additionalProperties": false,
      "description": "A reader label bound, when possible, to one primitive-graph node.",
