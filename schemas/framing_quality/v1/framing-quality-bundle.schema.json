          "enum": [
            "ResearchQuestion",
            "BenchmarkSet",
            "PrimitiveGraph"
          ],
          "title": "Entity Type",
          "type": "string"
        }
      },
      "required": [
        "entity_type",
        "entity_ref"
      ],
      "title": "FramingRepairTargetRef",
      "type": "object"
    },
