        "label": {
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "object_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Object Id",
          "type": "string"
        },
        "primitive_node_id": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Primitive Node Id"
        },
        "semantic_level": {
          "enum": [
            "primitive",
            "choice",
            "behavioral_response",
            "conditional_distribution",
            "transition_kernel",
            "stationary_distribution",
            "payoff_ledger",
            "equilibrium_object",
            "equilibrium_correspondence",
            "outcome",
            "aggregate"
          ],
          "title": "Semantic Level",
          "type": "string"
        }
      },
      "required": [
        "object_id",
        "label",
        "semantic_level"
      ],
      "title": "FramingObjectRef",
      "type": "object"
    },
    "FramingRepairTargetRef": {
