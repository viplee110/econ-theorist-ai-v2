{
  "$defs": {
    "EntityVersionRef": {
      "additionalProperties": false,
      "properties": {
        "entity_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Entity Id",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "entity_id",
        "version"
      ],
      "title": "EntityVersionRef",
      "type": "object"
    },
    "FacetPathRef": {
      "additionalProperties": false,
      "properties": {
        "entity_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Entity Id",
          "type": "string"
        },
        "facet": {
          "enum": [
            "formal",
            "economic_interpretation",
            "literature_novelty",
            "terminology_presentation",
            "authority"
          ],
          "title": "Facet",
          "type": "string"
        },
        "field_path": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Field Path"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "entity_id",
        "version",
        "facet"
      ],
      "title": "FacetPathRef",
      "type": "object"
    },
    "RelationVersionRef": {
      "additionalProperties": false,
      "properties": {
        "relation_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Relation Id",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "relation_id",
        "version"
      ],
      "title": "RelationVersionRef",
      "type": "object"
    },
    "ScopeOverlapEvidence": {
      "additionalProperties": false,
      "description": "Typed exact scope versions supporting one scope-sensitive dependency.",
      "properties": {
        "source_scope": {
          "$ref": "#/$defs/EntityVersionRef"
        },
        "target_scope": {
          "$ref": "#/$defs/EntityVersionRef"
        }
      },
      "required": [
        "source_scope",
        "target_scope"
      ],
      "title": "ScopeOverlapEvidence",
      "type": "object"
    },
    "SemanticFacetRef": {
      "additionalProperties": false,
      "properties": {
        "entity_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Entity Id",
          "type": "string"
        },
        "facet": {
          "enum": [
            "formal",
            "economic_interpretation",
            "literature_novelty",
            "terminology_presentation",
            "authority"
          ],
          "title": "Facet",
          "type": "string"
        },
        "field_path": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Field Path"
        },
        "semantic_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Semantic Hash",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "entity_id",
        "version",
        "facet",
        "semantic_hash"
      ],
      "title": "SemanticFacetRef",
      "type": "object"
    }
  },
  "$id": "https://econ-theorist.ai/schemas/v1/relation-version.schema.json",
  "additionalProperties": false,
  "properties": {
    "access_compartments": {
      "default": [
        "project_research"
      ],
      "items": {
        "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
        "type": "string"
      },
      "title": "Access Compartments",
      "type": "array"
    },
    "created_at": {
      "minLength": 1,
      "title": "Created At",
      "type": "string"
    },
    "dependency_mode": {
      "default": "trace_only",
      "enum": [
        "hard",
        "scope_sensitive",
        "evidentiary",
        "presentation",
        "trace_only"
      ],
      "title": "Dependency Mode",
      "type": "string"
    },
    "downstream": {
      "anyOf": [
        {
          "$ref": "#/$defs/FacetPathRef"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "privacy": {
      "default": "project_private",
      "enum": [
        "public",
        "project_private",
        "restricted",
        "local_only"
      ],
      "title": "Privacy",
      "type": "string"
    },
    "project_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
      "title": "Project Id",
      "type": "string"
    },
    "relation_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
      "title": "Relation Id",
      "type": "string"
    },
    "relation_type": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
      "title": "Relation Type",
      "type": "string"
    },
    "scope_overlap": {
      "anyOf": [
        {
          "$ref": "#/$defs/ScopeOverlapEvidence"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "scope_ref": {
      "anyOf": [
        {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Scope Ref"
    },
    "source": {
      "$ref": "#/$defs/EntityVersionRef"
    },
    "supersedes": {
      "anyOf": [
        {
          "$ref": "#/$defs/RelationVersionRef"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "target": {
      "$ref": "#/$defs/EntityVersionRef"
    },
    "upstream": {
      "anyOf": [
        {
          "$ref": "#/$defs/SemanticFacetRef"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "version": {
      "minimum": 1,
      "title": "Version",
      "type": "integer"
    }
  },
  "required": [
    "relation_id",
    "relation_type",
    "version",
    "project_id",
    "source",
    "target",
    "created_at"
  ],
  "title": "RelationVersion",
  "type": "object"
}
