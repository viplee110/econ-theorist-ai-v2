          "title": "Subject Type",
          "type": "string"
        }
      },
      "required": [
        "entity"
      ],
      "title": "EntityPrivacySubject",
      "type": "object"
    },
    "EntityVersion": {
      "additionalProperties": false,
      "properties": {
        "access_compartments": {
          "default": [
            "project_research"
          ],
          "items": {
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
            "type": "string"
          },
          "title": "Access Compartments",
          "type": "array"
        },
        "artifact_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactDependencyRef"
          },
          "title": "Artifact Refs",
          "type": "array"
        },
        "created_at": {
          "minLength": 1,
          "title": "Created At",
          "type": "string"
        },
        "entity_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Entity Id",
          "type": "string"
        },
        "entity_type": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Entity Type",
          "type": "string"
        },
        "facets": {
          "$ref": "#/$defs/FacetPayloads"
        },
        "privacy": {
          "default": "project_private",
          "enum": [
            "public",
            "project_private",
            "restricted",
            "local_only"
          ],
          "title": "Privacy",
          "type": "string"
        },
        "project_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Project Id",
          "type": "string"
        },
        "scope_ref": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Scope Ref"
        },
        "status": {
          "$ref": "#/$defs/ScientificStatus"
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "supersedes": {
          "anyOf": [
            {
              "$ref": "#/$defs/EntityVersionRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "title": {
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "entity_id",
        "entity_type",
        "version",
        "project_id",
        "title",
        "summary",
        "status",
        "facets",
        "created_at"
      ],
      "title": "EntityVersion",
      "type": "object"
    },
    "EntityVersionRef": {
      "additionalProperties": false,
      "properties": {
        "entity_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Entity Id",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "entity_id",
        "version"
      ],
      "title": "EntityVersionRef",
      "type": "object"
    },
    "FacetPathRef": {
      "additionalProperties": false,
      "properties": {
        "entity_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Entity Id",
          "type": "string"
        },
        "facet": {
          "enum": [
            "formal",
            "economic_interpretation",
            "literature_novelty",
            "terminology_presentation",
            "authority"
          ],
          "title": "Facet",
          "type": "string"
        },
        "field_path": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Field Path"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "entity_id",
        "version",
        "facet"
      ],
      "title": "FacetPathRef",
      "type": "object"
    },
    "FacetPayloads": {
      "additionalProperties": false,
      "description": "Generic Phase 1 payload partitioned into the five semantic facets.",
      "properties": {
        "authority": {
          "additionalProperties": true,
          "title": "Authority",
          "type": "object"
        },
        "economic_interpretation": {
          "additionalProperties": true,
          "title": "Economic Interpretation",
          "type": "object"
        },
        "formal": {
          "additionalProperties": true,
          "title": "Formal",
          "type": "object"
        },
        "literature_novelty": {
          "additionalProperties": true,
          "title": "Literature Novelty",
          "type": "object"
        },
        "terminology_presentation": {
          "additionalProperties": true,
          "title": "Terminology Presentation",
          "type": "object"
        }
      },
      "title": "FacetPayloads",
      "type": "object"
    },
    "LiteratureStatus": {
      "additionalProperties": false,
      "properties": {
        "coverage": {
          "enum": [
            "not_started",
            "partial",
            "current",
            "needs_refresh"
          ],
          "title": "Coverage",
          "type": "string"
        },
        "novelty": {
          "enum": [
            "unassessed",
            "unresolved",
            "differentiated",
            "absorbed",
            "disputed"
          ],
          "title": "Novelty",
          "type": "string"
        }
      },
      "required": [
        "coverage",
        "novelty"
      ],
      "title": "LiteratureStatus",
      "type": "object"
    },
    "Precondition": {
      "additionalProperties": false,
      "properties": {
        "entity": {
          "$ref": "#/$defs/EntityVersionRef"
        },
        "expected_semantic_hashes": {
          "additionalProperties": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "propertyNames": {
            "enum": [
              "formal",
              "economic_interpretation",
              "literature_novelty",
              "terminology_presentation",
              "authority"
            ]
          },
          "title": "Expected Semantic Hashes",
          "type": "object"
        }
      },
      "required": [
        "entity"
      ],
      "title": "Precondition",
      "type": "object"
    },
    "PrivacyChange": {
      "additionalProperties": false,
      "description": "One exact requested release of an immutable canonical object version.",
      "properties": {
        "from_privacy": {
          "enum": [
            "public",
            "project_private",
            "restricted",
            "local_only"
          ],
          "title": "From Privacy",
          "type": "string"
        },
        "subject": {
          "discriminator": {
            "mapping": {
              "artifact": "#/$defs/ArtifactPrivacySubject",
              "entity": "#/$defs/EntityPrivacySubject",
              "relation": "#/$defs/RelationPrivacySubject"
            },
            "propertyName": "subject_type"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/EntityPrivacySubject"
            },
            {
              "$ref": "#/$defs/RelationPrivacySubject"
            },
            {
              "$ref": "#/$defs/ArtifactPrivacySubject"
            }
          ],
          "title": "Subject"
        },
        "to_privacy": {
          "enum": [
            "public",
            "project_private",
            "restricted",
            "local_only"
          ],
          "title": "To Privacy",
          "type": "string"
        }
      },
      "required": [
        "subject",
        "from_privacy",
        "to_privacy"
      ],
      "title": "PrivacyChange",
      "type": "object"
    },
