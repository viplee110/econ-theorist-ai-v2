{
  "$id": "https://econ-theorist.ai/schemas/machine/v1/host-operation-receipt.schema.json",
  "additionalProperties": false,
  "properties": {
    "adapter_id": {
      "minLength": 1,
      "title": "Adapter Id",
      "type": "string"
    },
    "adapter_version": {
      "minLength": 1,
      "title": "Adapter Version",
      "type": "string"
    },
    "artifact_digests": {
      "items": {
        "pattern": "^[0-9a-f]{64}$",
        "type": "string"
      },
      "title": "Artifact Digests",
      "type": "array"
    },
    "candidate_digest": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Candidate Digest"
    },
    "commit_outcome": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Commit Outcome"
    },
    "completed_at": {
      "minLength": 1,
      "title": "Completed At",
      "type": "string"
    },
    "completion_status": {
      "enum": [
        "completed",
        "failed_no_effect",
        "failed_terminal",
        "cancelled",
        "unknown_possible_effect",
        "unknown_possible_egress"
      ],
      "title": "Completion Status",
      "type": "string"
    },
    "delivery_envelope_hash": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Delivery Envelope Hash"
    },
    "head_after": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Head After"
    },
    "head_before": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Head Before"
    },
    "host_product": {
      "minLength": 1,
      "title": "Host Product",
      "type": "string"
    },
    "host_receipt_schema": {
      "const": "econ-theorist/host-operation-receipt/v1",
      "default": "econ-theorist/host-operation-receipt/v1",
      "title": "Host Receipt Schema",
      "type": "string"
    },
    "host_version": {
      "minLength": 1,
      "title": "Host Version",
      "type": "string"
    },
    "model": {
      "minLength": 1,
      "title": "Model",
      "type": "string"
    },
    "operation_key": {
      "pattern": "^[A-Za-z][A-Za-z0-9._:-]{0,127}$",
      "title": "Operation Key",
      "type": "string"
    },
    "provider": {
      "minLength": 1,
      "title": "Provider",
      "type": "string"
    },
    "reasoning_class": {
      "minLength": 1,
      "title": "Reasoning Class",
      "type": "string"
    },
    "stage_outcome": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Stage Outcome"
    },
    "tool_identities": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Tool Identities",
      "type": "array"
    },
    "warnings": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    },
    "work_packet_hash": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Work Packet Hash"
    }
  },
  "required": [
    "delivery_envelope_hash",
    "work_packet_hash",
    "operation_key",
    "host_product",
    "host_version",
    "adapter_id",
    "adapter_version",
    "provider",
    "model",
    "reasoning_class",
    "tool_identities",
    "candidate_digest",
    "artifact_digests",
    "stage_outcome",
    "commit_outcome",
    "head_before",
    "head_after",
    "warnings",
    "completion_status",
    "completed_at"
  ],
  "title": "HostOperationReceiptV1",
  "type": "object"
}
