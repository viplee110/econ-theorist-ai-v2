{
  "$defs": {
    "EngineResourceV1": {
      "additionalProperties": false,
      "properties": {
        "byte_size": {
          "minimum": 0,
          "title": "Byte Size",
          "type": "integer"
        },
        "logical_path": {
          "minLength": 1,
          "title": "Logical Path",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "logical_path",
        "sha256",
        "byte_size"
      ],
      "title": "EngineResourceV1",
      "type": "object"
    }
  },
  "$id": "https://econ-theorist.ai/schemas/machine/v1/installed-distribution.schema.json",
  "additionalProperties": false,
  "properties": {
    "file_inventory_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "File Inventory Hash",
      "type": "string"
    },
    "files": {
      "items": {
        "$ref": "#/$defs/EngineResourceV1"
      },
      "minItems": 1,
      "title": "Files",
      "type": "array"
    },
    "name": {
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "version": {
      "minLength": 1,
      "title": "Version",
      "type": "string"
    }
  },
  "required": [
    "name",
    "version",
    "files",
    "file_inventory_hash"
  ],
  "title": "InstalledDistributionV1",
  "type": "object"
}
