{
  "$id": "https://econ-theorist.ai/schemas/machine/v1/delivery-envelope.schema.json",
  "additionalProperties": false,
  "properties": {
    "adapter_id": {
      "minLength": 1,
      "title": "Adapter Id",
      "type": "string"
    },
    "adapter_version": {
      "minLength": 1,
      "title": "Adapter Version",
      "type": "string"
    },
    "agent_topology": {
      "const": "single",
      "default": "single",
      "title": "Agent Topology",
      "type": "string"
    },
    "candidate_root": {
      "minLength": 1,
      "title": "Candidate Root",
      "type": "string"
    },
    "capability_receipt_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Capability Receipt Hash",
      "type": "string"
    },
    "cross_run_memory_disabled": {
      "title": "Cross Run Memory Disabled",
      "type": "boolean"
    },
    "delivery_time": {
      "minLength": 1,
      "title": "Delivery Time",
      "type": "string"
    },
    "egress_authorization_hash": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Egress Authorization Hash"
    },
    "egress_plan_hash": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Egress Plan Hash"
    },
    "envelope_schema": {
      "const": "econ-theorist/delivery-envelope/v1",
      "default": "econ-theorist/delivery-envelope/v1",
      "title": "Envelope Schema",
      "type": "string"
    },
    "host_manifest_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Host Manifest Hash",
      "type": "string"
    },
    "host_product": {
      "minLength": 1,
      "title": "Host Product",
      "type": "string"
    },
    "host_session_id": {
      "minLength": 1,
      "title": "Host Session Id",
      "type": "string"
    },
    "host_version": {
      "minLength": 1,
      "title": "Host Version",
      "type": "string"
    },
    "operation_key": {
      "pattern": "^[A-Za-z][A-Za-z0-9._:-]{0,127}$",
      "title": "Operation Key",
      "type": "string"
    },
    "pre_delivery_status": {
      "enum": [
        "authorized_to_deliver",
        "blocked_before_delivery"
      ],
      "title": "Pre Delivery Status",
      "type": "string"
    },
    "project_root": {
      "minLength": 1,
      "title": "Project Root",
      "type": "string"
    },
    "projection_hash": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Projection Hash"
    },
    "projection_id": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Projection Id"
    },
    "session_fresh": {
      "title": "Session Fresh",
      "type": "boolean"
    },
    "work_packet_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Work Packet Hash",
      "type": "string"
    }
  },
  "required": [
    "work_packet_hash",
    "operation_key",
    "host_product",
    "host_version",
    "adapter_id",
    "adapter_version",
    "host_session_id",
    "session_fresh",
    "cross_run_memory_disabled",
    "project_root",
    "candidate_root",
    "projection_id",
    "projection_hash",
    "host_manifest_hash",
    "capability_receipt_hash",
    "egress_plan_hash",
    "egress_authorization_hash",
    "delivery_time",
    "pre_delivery_status"
  ],
  "title": "DeliveryEnvelopeV1",
  "type": "object"
}
