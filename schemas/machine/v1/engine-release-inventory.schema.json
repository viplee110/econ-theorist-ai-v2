          "type": "string"
        },
        "files": {
          "items": {
            "$ref": "#/$defs/EngineResourceV1"
          },
          "minItems": 1,
          "title": "Files",
          "type": "array"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "name",
        "version",
        "files",
        "file_inventory_hash"
      ],
      "title": "InstalledDistributionV1",
      "type": "object"
    }
  },
  "$id": "https://econ-theorist.ai/schemas/machine/v1/engine-release-inventory.schema.json",
  "additionalProperties": false,
  "properties": {
    "distributions": {
      "items": {
        "$ref": "#/$defs/InstalledDistributionV1"
      },
      "minItems": 1,
      "title": "Distributions",
      "type": "array"
    },
    "engine_version": {
      "minLength": 1,
      "title": "Engine Version",
      "type": "string"
    },
    "host_manifest_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Host Manifest Hash",
      "type": "string"
    },
    "inventory_schema": {
      "const": "econ-theorist/engine-release-inventory/v1",
