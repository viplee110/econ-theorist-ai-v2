{
  "$defs": {
    "Actor": {
      "additionalProperties": false,
      "properties": {
        "actor_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Actor Id",
          "type": "string"
        },
        "kind": {
          "enum": [
            "human",
            "agent",
            "deterministic_tool"
          ],
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "actor_id"
      ],
      "title": "Actor",
      "type": "object"
    },
    "ArtifactDependencyRef": {
      "additionalProperties": false,
      "description": "Exact immutable artifact bytes consumed by a canonical entity.",
      "properties": {
        "artifact_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Artifact Id",
          "type": "string"
        },
        "content_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "artifact_id",
        "version",
        "content_hash"
      ],
      "title": "ArtifactDependencyRef",
      "type": "object"
    },
    "AssuranceIssue": {
      "additionalProperties": false,
      "properties": {
        "affected_refs": {
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/EntityVersionRef"
              },
              {
                "$ref": "#/$defs/ArtifactDependencyRef"
              },
              {
                "$ref": "#/$defs/DecisionVersionRef"
              }
            ]
          },
          "minItems": 1,
          "title": "Affected Refs",
          "type": "array"
        },
        "blocking": {
          "title": "Blocking",
          "type": "boolean"
        },
        "issue_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Issue Id",
          "type": "string"
        },
        "severity": {
          "enum": [
            "info",
            "warning",
            "error",
            "critical"
          ],
          "title": "Severity",
          "type": "string"
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "issue_id",
        "severity",
        "summary",
        "affected_refs",
        "blocking"
      ],
      "title": "AssuranceIssue",
      "type": "object"
    },
    "CounterexampleScanEvidence": {
      "additionalProperties": false,
      "properties": {
        "cases": {
          "items": {
            "$ref": "#/$defs/ExactAssignmentSpec"
          },
          "minItems": 1,
          "title": "Cases",
          "type": "array"
        },
        "checked_count": {
          "minimum": 1,
          "title": "Checked Count",
          "type": "integer"
        },
        "code_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Code Hash",
          "type": "string"
        },
        "domain_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Domain Hash",
          "type": "string"
        },
        "evidentiary_limit": {
          "const": "No witness in a finite exact domain is corroboration, not proof of a universal claim.",
          "default": "No witness in a finite exact domain is corroboration, not proof of a universal claim.",
          "title": "Evidentiary Limit",
          "type": "string"
        },
        "input_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Input Hash",
          "type": "string"
        },
        "outcome": {
          "enum": [
            "falsified",
            "no_counterexample_found"
          ],
          "title": "Outcome",
          "type": "string"
        },
        "output_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Output Hash",
          "type": "string"
        },
        "predicate": {
          "$ref": "#/$defs/PolynomialRelationPredicate"
        },
        "protocol": {
          "const": "exact_polynomial_relation_scan.v1",
          "default": "exact_polynomial_relation_scan.v1",
          "title": "Protocol",
          "type": "string"
        },
        "receipt_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Receipt Hash",
          "type": "string"
        },
        "relation_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Relation Hash",
          "type": "string"
        },
        "witness_case_id": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Witness Case Id"
        },
        "witness_hash": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Witness Hash"
        }
      },
      "required": [
        "predicate",
        "cases",
        "code_hash",
        "input_hash",
        "output_hash",
        "domain_hash",
        "relation_hash",
        "checked_count",
        "outcome",
        "receipt_hash"
      ],
      "title": "CounterexampleScanEvidence",
      "type": "object"
    },
    "DecisionVersionRef": {
      "additionalProperties": false,
      "properties": {
        "decision_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Decision Id",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "decision_id",
        "version"
      ],
      "title": "DecisionVersionRef",
      "type": "object"
    },
    "EntityVersionRef": {
      "additionalProperties": false,
      "properties": {
        "entity_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Entity Id",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "entity_id",
        "version"
      ],
      "title": "EntityVersionRef",
      "type": "object"
    },
    "ExactAssignmentSpec": {
      "additionalProperties": false,
      "properties": {
        "case_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Case Id",
          "type": "string"
        },
        "values": {
          "items": {
            "$ref": "#/$defs/ExactAssignmentValue"
          },
          "minItems": 1,
          "title": "Values",
          "type": "array"
        }
      },
      "required": [
        "case_id",
        "values"
      ],
      "title": "ExactAssignmentSpec",
      "type": "object"
    },
    "ExactAssignmentValue": {
      "additionalProperties": false,
      "properties": {
        "value": {
          "$ref": "#/$defs/ExactRationalValue"
        },
        "variable": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Variable",
          "type": "string"
        }
      },
      "required": [
        "variable",
        "value"
      ],
      "title": "ExactAssignmentValue",
      "type": "object"
    },
    "ExactPolynomialSpec": {
      "additionalProperties": false,
      "properties": {
        "terms": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ExactPolynomialTermSpec"
          },
          "title": "Terms",
          "type": "array"
        }
      },
      "title": "ExactPolynomialSpec",
      "type": "object"
    },
    "ExactPolynomialTermSpec": {
      "additionalProperties": false,
      "properties": {
        "coefficient": {
          "$ref": "#/$defs/ExactRationalValue"
        },
        "powers": {
          "default": [],
          "items": {
            "$ref": "#/$defs/PolynomialPowerSpec"
          },
          "title": "Powers",
          "type": "array"
        }
      },
      "required": [
        "coefficient"
      ],
      "title": "ExactPolynomialTermSpec",
      "type": "object"
    },
    "ExactRationalValue": {
      "additionalProperties": false,
      "properties": {
        "denominator": {
          "minimum": 1,
          "title": "Denominator",
          "type": "integer"
        },
        "numerator": {
          "title": "Numerator",
          "type": "integer"
        }
      },
      "required": [
        "numerator",
        "denominator"
      ],
      "title": "ExactRationalValue",
      "type": "object"
    },
    "HarnessNonApplicabilityRecord": {
      "additionalProperties": false,
      "properties": {
        "claim_graph_ref": {
          "$ref": "#/$defs/EntityVersionRef"
        },
        "claim_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Claim Id",
          "type": "string"
        },
        "determined_by": {
          "$ref": "#/$defs/Actor"
        },
        "evidence_refs": {
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/EntityVersionRef"
              },
              {
                "$ref": "#/$defs/ArtifactDependencyRef"
              },
              {
                "$ref": "#/$defs/DecisionVersionRef"
              }
            ]
          },
          "minItems": 1,
          "title": "Evidence Refs",
          "type": "array"
        },
        "explanation": {
          "minLength": 32,
          "title": "Explanation",
          "type": "string"
        },
        "family": {
          "enum": [
            "symbolic_identity",
            "counterexample_search"
          ],
          "title": "Family",
          "type": "string"
        },
        "obligation_ref": {
          "$ref": "#/$defs/EntityVersionRef"
        },
        "reason_code": {
          "enum": [
            "no_algebraic_identity",
            "no_finite_domain",
            "check_not_informative",
            "covered_by_stronger_exact_argument"
          ],
          "title": "Reason Code",
          "type": "string"
        },
        "record_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Record Id",
          "type": "string"
        }
      },
      "required": [
        "record_id",
        "family",
        "claim_graph_ref",
        "claim_id",
        "obligation_ref",
        "reason_code",
        "explanation",
        "evidence_refs",
        "determined_by"
      ],
      "title": "HarnessNonApplicabilityRecord",
      "type": "object"
    },
    "PolynomialPowerSpec": {
      "additionalProperties": false,
      "properties": {
        "power": {
          "minimum": 1,
          "title": "Power",
          "type": "integer"
        },
        "variable": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Variable",
          "type": "string"
        }
      },
      "required": [
        "variable",
        "power"
      ],
      "title": "PolynomialPowerSpec",
      "type": "object"
    },
    "PolynomialRelationPredicate": {
      "additionalProperties": false,
      "properties": {
        "left": {
          "$ref": "#/$defs/ExactPolynomialSpec"
        },
        "relation": {
          "enum": [
            "eq",
            "le",
            "lt",
            "ge",
            "gt"
          ],
          "title": "Relation",
          "type": "string"
        },
        "right": {
          "$ref": "#/$defs/ExactPolynomialSpec"
        }
      },
      "required": [
        "left",
        "relation",
        "right"
      ],
      "title": "PolynomialRelationPredicate",
      "type": "object"
    },
    "ProofAudit": {
      "additionalProperties": false,
      "properties": {
        "assumption_map_ref": {
          "$ref": "#/$defs/EntityVersionRef"
        },
        "audit_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Audit Id",
          "type": "string"
        },
        "audit_report_ref": {
          "$ref": "#/$defs/ArtifactDependencyRef"
        },
        "audited_at": {
          "minLength": 1,
          "title": "Audited At",
          "type": "string"
        },
        "auditor": {
          "$ref": "#/$defs/Actor"
        },
        "claim_graph_ref": {
          "$ref": "#/$defs/EntityVersionRef"
        },
        "claim_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Claim Id",
          "type": "string"
        },
        "comparison_outcome": {
          "enum": [
            "agrees",
            "gap_found",
            "falsified",
            "inconclusive"
          ],
          "title": "Comparison Outcome",
          "type": "string"
        },
        "findings": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ProofAuditFinding"
          },
          "title": "Findings",
          "type": "array"
        },
        "formal_model_ref": {
          "$ref": "#/$defs/EntityVersionRef"
        },
        "limitations": {
          "minLength": 1,
          "title": "Limitations",
          "type": "string"
        },
        "obligation_ref": {
          "$ref": "#/$defs/EntityVersionRef"
        },
        "originating_verifier": {
          "$ref": "#/$defs/Actor"
        },
        "outcome": {
          "enum": [
            "passed",
            "gap_found",
            "falsified",
            "inconclusive"
          ],
          "title": "Outcome",
          "type": "string"
        },
        "proof_artifact_ref": {
          "$ref": "#/$defs/ArtifactDependencyRef"
        },
        "rederivation_ref": {
          "$ref": "#/$defs/EntityVersionRef"
        },
        "verification_record_ref": {
          "$ref": "#/$defs/EntityVersionRef"
        }
      },
      "required": [
        "audit_id",
        "claim_graph_ref",
        "claim_id",
        "obligation_ref",
        "formal_model_ref",
        "assumption_map_ref",
        "proof_artifact_ref",
        "verification_record_ref",
        "rederivation_ref",
        "originating_verifier",
        "auditor",
        "audit_report_ref",
        "outcome",
        "comparison_outcome",
        "limitations",
        "audited_at"
      ],
      "title": "ProofAudit",
      "type": "object"
    },
    "ProofAuditFinding": {
      "additionalProperties": false,
      "properties": {
        "evidence_refs": {
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/EntityVersionRef"
              },
              {
                "$ref": "#/$defs/ArtifactDependencyRef"
              },
              {
                "$ref": "#/$defs/DecisionVersionRef"
              }
            ]
          },
          "minItems": 1,
          "title": "Evidence Refs",
          "type": "array"
        },
        "finding_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Finding Id",
          "type": "string"
        },
        "kind": {
          "enum": [
            "hidden_assumption",
            "direction_error",
            "missing_existence",
            "missing_uniqueness",
            "quantifier_gap",
            "domain_gap",
            "boundary_gap",
            "unsupported_step",
            "notation_mismatch",
            "other"
          ],
          "title": "Kind",
          "type": "string"
        },
        "severity": {
          "enum": [
            "info",
            "warning",
            "error",
            "critical"
          ],
          "title": "Severity",
          "type": "string"
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "finding_id",
        "kind",
        "severity",
        "summary",
        "evidence_refs"
      ],
      "title": "ProofAuditFinding",
      "type": "object"
    },
    "SymbolicIdentityEvidence": {
      "additionalProperties": false,
      "properties": {
        "certificate_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Certificate Hash",
          "type": "string"
        },
        "difference_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Difference Hash",
          "type": "string"
        },
        "input_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Input Hash",
          "type": "string"
        },
        "left": {
          "$ref": "#/$defs/ExactPolynomialSpec"
        },
        "left_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Left Hash",
          "type": "string"
        },
        "outcome": {
          "enum": [
            "identity_verified",
            "identity_failed"
          ],
          "title": "Outcome",
          "type": "string"
        },
        "output_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Output Hash",
          "type": "string"
        },
        "protocol": {
          "const": "exact_polynomial_identity.v1",
          "default": "exact_polynomial_identity.v1",
          "title": "Protocol",
          "type": "string"
        },
        "right": {
          "$ref": "#/$defs/ExactPolynomialSpec"
        },
        "right_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Right Hash",
          "type": "string"
        }
      },
      "required": [
        "left",
        "right",
        "input_hash",
        "output_hash",
        "left_hash",
        "right_hash",
        "difference_hash",
        "outcome",
        "certificate_hash"
      ],
      "title": "SymbolicIdentityEvidence",
      "type": "object"
    },
    "ToolHarnessReceipt": {
      "additionalProperties": false,
      "properties": {
        "certificate_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactDependencyRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "claim_graph_ref": {
          "$ref": "#/$defs/EntityVersionRef"
        },
        "claim_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Claim Id",
          "type": "string"
        },
        "code_ref": {
          "$ref": "#/$defs/ArtifactDependencyRef"
        },
        "domain": {
          "minLength": 1,
          "title": "Domain",
          "type": "string"
        },
        "evidentiary_role": {
          "enum": [
            "exact_identity_certificate",
            "corroboration_only",
            "falsification",
            "diagnostic"
          ],
          "title": "Evidentiary Role",
          "type": "string"
        },
        "executed_at": {
          "minLength": 1,
          "title": "Executed At",
          "type": "string"
        },
        "harness_kind": {
          "enum": [
            "symbolic_identity",
            "counterexample_search",
            "finite_grid"
          ],
          "title": "Harness Kind",
          "type": "string"
        },
        "input_ref": {
          "$ref": "#/$defs/ArtifactDependencyRef"
        },
        "limitations": {
          "minLength": 1,
          "title": "Limitations",
          "type": "string"
        },
        "obligation_ref": {
          "$ref": "#/$defs/EntityVersionRef"
        },
        "outcome": {
          "enum": [
            "identity_verified",
            "witness_found",
            "no_counterexample_found",
            "failed",
            "inconclusive"
          ],
          "title": "Outcome",
          "type": "string"
        },
        "output_ref": {
          "$ref": "#/$defs/ArtifactDependencyRef"
        },
        "receipt_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
          "title": "Receipt Id",
          "type": "string"
        },
        "receipt_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactDependencyRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "reproducible_evidence": {
          "anyOf": [
            {
              "discriminator": {
                "mapping": {
                  "exact_polynomial_identity.v1": "#/$defs/SymbolicIdentityEvidence",
                  "exact_polynomial_relation_scan.v1": "#/$defs/CounterexampleScanEvidence"
                },
                "propertyName": "protocol"
              },
              "oneOf": [
                {
                  "$ref": "#/$defs/SymbolicIdentityEvidence"
                },
                {
                  "$ref": "#/$defs/CounterexampleScanEvidence"
                }
              ]
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reproducible Evidence"
        },
        "seed": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Seed"
        },
        "tool_name": {
          "minLength": 1,
          "title": "Tool Name",
          "type": "string"
        },
        "tool_version": {
          "minLength": 1,
          "title": "Tool Version",
          "type": "string"
        },
        "witness_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactDependencyRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "receipt_id",
        "harness_kind",
        "claim_graph_ref",
        "claim_id",
        "obligation_ref",
        "tool_name",
        "tool_version",
        "code_ref",
        "input_ref",
        "output_ref",
        "domain",
        "outcome",
        "evidentiary_role",
        "limitations",
        "executed_at"
      ],
      "title": "ToolHarnessReceipt",
      "type": "object"
    }
  },
  "$id": "https://econ-theorist.ai/schemas/authoring/v1/assurance-bundle.schema.json",
  "additionalProperties": false,
  "properties": {
    "assembled_at": {
      "minLength": 1,
      "title": "Assembled At",
      "type": "string"
    },
    "assembled_by": {
      "$ref": "#/$defs/Actor"
    },
    "assumption_map_ref": {
      "$ref": "#/$defs/EntityVersionRef"
    },
    "claim_graph_ref": {
      "$ref": "#/$defs/EntityVersionRef"
    },
    "compiled_context_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Compiled Context Hash",
      "type": "string"
    },
    "context_manifest_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Context Manifest Hash",
      "type": "string"
    },
    "formal_model_ref": {
      "$ref": "#/$defs/EntityVersionRef"
    },
    "g5_decision_ref": {
      "$ref": "#/$defs/DecisionVersionRef"
    },
    "headline_claim_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]*$",
      "title": "Headline Claim Id",
      "type": "string"
    },
    "package_ref": {
      "$ref": "#/$defs/EntityVersionRef"
    },
    "proof_audits": {
      "items": {
        "$ref": "#/$defs/ProofAudit"
      },
